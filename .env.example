# BetterAuth
BETTER_AUTH_URL=http://localhost:5173
BETTER_AUTH_SECRET=your-development-secret-key-min-32-chars

# Email (Resend)
RESEND_API_KEY=re_your_key_here

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# Cloudflare Turnstile (bot protection on signup)
# Use 1x0000000000000000000000000000000AA for local dev (always passes)
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Optional: field encryption
# API_ENCRYPTION_KEY=generate with: openssl rand -hex 32